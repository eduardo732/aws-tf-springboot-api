# Copia este archivo a terraform.tfvars y ajusta los valores según tu entorno

# Región de AWS donde se desplegará la infraestructura
aws_region = "us-east-1"

# Nombre del proyecto (se usa para nombrar recursos)
project_name = "springboot-api"

# Entorno (dev, staging, prod)
environment = "dev"

# Tipo de instancia EC2
# t3.medium recomendado para LocalStack + Spring Boot
# Para producción considera t3.large o superior
instance_type = "t3.medium"

# Ruta a tu clave pública SSH (debe existir)
# Genera con: ssh-keygen -t rsa -b 4096 -f ~/.ssh/aws-springboot-key
public_key_path = "~/.ssh/id_rsa.pub"

# URL del repositorio Git
git_repository = "https://github.com/eduardo732/aws-tf-springboot-api.git"

# IMPORTANTE: Restringe el acceso SSH solo a tu IP pública
# Obtén tu IP con: curl ifconfig.me
# Formato: ["TU_IP/32"]
allowed_ssh_cidrs = ["0.0.0.0/0"]

# IMPORTANTE: Restringe el acceso a LocalStack solo a tu IP
# En producción, LocalStack no debería ser accesible públicamente
allowed_localstack_cidrs = ["0.0.0.0/0"]

